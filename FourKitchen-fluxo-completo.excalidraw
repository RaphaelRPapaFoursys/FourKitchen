      "updated": 1,
      "link": null,
      "locked": false,
      "text": "FRONTEND ANGULAR :4200\n\nRotas:\n/login\n/gestor\n/garcom\n/cozinha\n/mesa\n/totem\n/home\n\nAuthService:\n- envia email + senha\n- salva accessToken\n- consulta /api/auth/me\n\nGuards:\n- valida token\n- valida perfil\n- redireciona por perfil",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FRONTEND ANGULAR :4200\n\nRotas:\n/login\n/gestor\n/garcom\n/cozinha\n/mesa\n/totem\n/home\n\nAuthService:\n- envia email + senha\n- salva accessToken\n- consulta /api/auth/me\n\nGuards:\n- valida token\n- valida perfil\n- redireciona por perfil",
      "lineHeight": 1.25,
      "baseline": 326
    },
