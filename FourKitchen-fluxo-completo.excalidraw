      "link": null,
      "locked": false,
      "text": "BFF RESTAURANTE :8080\n\nEntrada unica do front:\n/api/auth\n/api/gestor\n/api/garcom\n/api/cozinha\n/api/mesa\n/api/totem\n/api/notificacoes\n\nResponsabilidades:\n- CORS\n- JWT stateless\n- autorizacao por role\n- orquestra Feign clients\n- padroniza erros",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "BFF RESTAURANTE :8080\n\nEntrada unica do front:\n/api/auth\n/api/gestor\n/api/garcom\n/api/cozinha\n/api/mesa\n/api/totem\n/api/notificacoes\n\nResponsabilidades:\n- CORS\n- JWT stateless\n- autorizacao por role\n- orquestra Feign clients\n- padroniza erros",
      "lineHeight": 1.25,
      "baseline": 326
